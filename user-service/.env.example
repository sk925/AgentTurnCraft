# 复制为 user-service 目录下的 `.env` 后修改。
# 数据库：与 backend 相同，使用环境变量 DATABASE_URL（参见 backend/.env.example）。

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_manage
SNOWFLAKE_WORKER_ID=1

# 本地开发若不用 Postgres，可改为 SQLite（无需安装 psycopg）：
# DATABASE_URL=sqlite:////absolute/path/to/user_service.db

JWT_SECRET_KEY=please-set-a-long-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 可选：使用其它路径的 dotenv（默认 user-service/.env）
# USER_SERVICE_DOTENV_PATH=/path/to/your/user-service.env
