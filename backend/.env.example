# 复制为 .env 后按需修改

# 日志：development=文本；production=JSON（容器 stdout 采集）
APP_ENV=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_manage
UPLOAD_DIR=.uploads/skills

# 须与 user-service 的 JWT_SECRET_KEY 一致，否则无法校验登录 token
JWT_SECRET_KEY=change-me-in-production-use-32bytes-min
JWT_ALGORITHM=HS256

# MinIO（S3 兼容 API）
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=free-chat
