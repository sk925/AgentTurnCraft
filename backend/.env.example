# 复制为 .env 后按需修改（勿提交 .env 到 Git）
# 变量名与 backend/app/config.py 中 Settings 字段对应（Pydantic 自动读取大写环境变量）

# ---------- 应用 ----------
APP_ENV=development
LOG_LEVEL=INFO

# ---------- 数据库（PostgreSQL，兼 LangGraph Checkpointer） ----------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_manage

# ---------- Redis（WebSocket 事件 Pub/Sub） ----------
REDIS_URL=redis://localhost:6379/0

# ---------- JWT 认证 ----------
# 生产环境务必更换为足够长的随机密钥
JWT_SECRET_KEY=change-me-in-production-use-32bytes-min
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---------- 本地上传（技能包等） ----------
UPLOAD_DIR=.uploads/skills

# ---------- MinIO（S3 兼容，附件/文件预览） ----------
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=agent-turncraft

# ---------- 群聊：超级助手选 Agent ----------
AGENT_SELECTOR_MODEL_NAME=gpt-4o-mini
AGENT_SELECTOR_MODEL_BASE_URL=https://api.openai.com/v1
AGENT_SELECTOR_MODEL_API_KEY=your-api-key

# ---------- 群聊：选发言人 / 发言相关模型 ----------
SPEAKER_MODEL_NAME=gpt-4o-mini
SPEAKER_MODEL_BASE_URL=https://api.openai.com/v1
SPEAKER_MODEL_API_KEY=your-api-key

# ---------- 单聊默认智能体（agents 表中的 id） ----------
DEFAULT_SINGLE_AGENT_ID=1

# ---------- 单聊上下文滚动摘要（轮次结束后压缩 checkpoint） ----------
# SUMMARY_ENABLED=true
# SUMMARY_TRIGGER_TOKENS=12000
# SUMMARY_KEEP_MESSAGES=24
# 未配置时复用 AGENT_SELECTOR_MODEL_* 
# SUMMARY_MODEL_NAME=gpt-4o-mini
# SUMMARY_MODEL_BASE_URL=https://api.openai.com/v1
# SUMMARY_MODEL_API_KEY=your-api-key

# ---------- 开放单聊（Android 等第三方，免 JWT 登录） ----------
# PUBLIC_CHAT_ENABLED=true 后可用 POST /api/open/chat/single
# 若配置了 PUBLIC_CHAT_API_KEY，客户端须在请求头携带 X-App-Key
PUBLIC_CHAT_ENABLED=false
PUBLIC_CHAT_API_KEY=
PUBLIC_CHAT_USER_ID=1

# ---------- Docker 沙箱（可选，见 app/sandbox/INTEGRATION.md） ----------
# AGENT_SANDBOX_IMAGE=python:3.12-slim
# AGENT_SANDBOX_ARTIFACT_ROOT=workspace
# AGENT_SANDBOX_NETWORK_DISABLED=true
# AGENT_SANDBOX_TIMEOUT=120
# AGENT_SANDBOX_IDLE_TTL_SECONDS=86400
